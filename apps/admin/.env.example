# GitHub token used to dispatch the generate.yml workflow and poll workflow
# run status. Needs `actions:write` (or a classic PAT with `repo` + `workflow`
# scopes) on GITHUB_DESIGN_SYSTEM_REPO below.
GITHUB_TOKEN=

# Postgres connection string for the job store (apps/admin/lib/jobs.ts).
# If you attach a Vercel Postgres/Neon to this project, POSTGRES_URL is injected
# automatically and used out of the box -- you DON'T need to set anything here.
# JOB_DB_URL is only an optional OVERRIDE (a different DB, or a non-Vercel
# Postgres). Any Postgres works (postgres.js driver). Resolution:
# JOB_DB_URL ?? POSTGRES_URL.
# JOB_DB_URL=

# "owner/repo" of this design-system repo, used to build the GitHub Actions
# dispatch/run-status API URLs.
GITHUB_DESIGN_SYSTEM_REPO=D-2-G-8/design-system

# NOTE: FIGMA_ACCESS_TOKEN and ANTHROPIC_API_KEY are NOT set here -- they are
# GitHub Actions repo secrets consumed by .github/workflows/generate.yml
# (the worker), not by this admin app.
