{
  "name": "@d-2-g-8/design-system",
  "version": "0.1.1",
  "description": "Shared React component library, generated and kept in sync from Figma by ai-tools-app.",
  "license": "UNLICENSED",
  "private": false,
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/design-system.cjs",
  "module": "./dist/design-system.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/design-system.js",
      "require": "./dist/design-system.cjs"
    },
    "./tokens.css": "./dist/tokens.css",
    "./style.css": "./dist/design-system.css"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/D-2-G-8/design-system.git"
  },
  "scripts": {
    "build": "vite build && cp src/tokens/tokens.css dist/tokens.css",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/react-vite": "^8.6.14",
    "@storybook/react": "^8.6.14",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.39.5",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "storybook": "^8.6.14",
    "typescript": "^5.9.3",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.5.0",
    "@types/node": "^22.10.0"
  },
  "packageManager": "pnpm@10.18.0"
}
