# Require the Node version to match "engines" in package.json —
# so local development doesn't drift from the Vercel runtime.
engine-strict=true

# Don't fail or prompt interactively over peer-dependency conflicts —
# convenient for a small project with a fast-changing set of packages.
auto-install-peers=true
strict-peer-dependencies=false

# Don't hoist packages to the root node_modules unless they are explicitly
# declared in package.json — a predictable dependency tree (pnpm's default behavior).
shamefully-hoist=false

registry=https://registry.npmjs.org/